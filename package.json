{
  "name": "cityscraper",
  "version": "1.0.0",
  "private": true,
  "description": "CityScraper.org - Advanced Multi-Site Aggregator Engine powering YardShoppers, CheapHouseHub, and CryptoToolbox",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "scrape:yards": "npx tsx src/lib/scrapers/yard-sale-scraper.ts",
    "scrape:homes": "npx tsx src/lib/scrapers/home-scraper.ts",
    "scrape:crypto": "npx tsx src/lib/scrapers/crypto-scraper.ts",
    "scrape:all": "npm run scrape:yards && npm run scrape:homes && npm run scrape:crypto",
    "push:all": "npx tsx src/lib/pushers/push-all.ts",
    "db:migrate": "npx tsx supabase/migrate.ts"
  },
  "dependencies": {
    "next": "14.2.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@supabase/supabase-js": "^2.45.0",
    "axios": "^1.7.3",
    "cheerio": "^1.0.0-rc.12",
    "puppeteer-core": "^23.0.0",
    "@sparticuz/chromium": "^126.0.0",
    "cron": "^3.1.7",
    "date-fns": "^3.6.0",
    "framer-motion": "^11.3.24",
    "lucide-react": "^0.427.0",
    "recharts": "^2.12.7",
    "zustand": "^4.5.4",
    "zod": "^3.23.8",
    "p-queue": "^8.0.1",
    "robotstxt-parser": "^0.1.1",
    "user-agents": "^1.1.245"
  },
  "devDependencies": {
    "@types/node": "^22.1.0",
    "@types/react": "^18.3.3",
    "@types/react-dom": "^18.3.0",
    "autoprefixer": "^10.4.20",
    "eslint": "^8.57.0",
    "eslint-config-next": "14.2.5",
    "postcss": "^8.4.41",
    "tailwindcss": "^3.4.9",
    "tsx": "^4.17.0",
    "typescript": "^5.5.4"
  }
}
